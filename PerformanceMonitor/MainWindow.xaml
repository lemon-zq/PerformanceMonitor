<Window x:Class="PerformanceMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PerformanceMonitor"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"  xmlns:lvc1="clr-namespace:LiveCharts;assembly=LiveCharts"
        mc:Ignorable="d"
        Title="高级系统性能监控器" Height="800" Width="1000"
        WindowStartupLocation="CenterScreen" Background="#FF1E1E1E" WindowStyle="None"    AllowsTransparency="False"
        ResizeMode="CanResize"     WindowChrome.IsHitTestVisibleInChrome="True">

    <Window.Resources>
        <!-- 样式定义 -->
        <Style TargetType="TextBlock" x:Key="TitleText">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="ValueText">
            <Setter Property="Foreground" Value="#FFE0E0E0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- 修复后的 ProgressBar 样式 -->
        <Style TargetType="ProgressBar">
            <Setter Property="Foreground" Value="#FF00BFFF"/>
            <Setter Property="Background" Value="#FF333333"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="25"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="TemplateRoot" SnapsToDevicePixels="true">
                            <Rectangle Fill="{TemplateBinding Background}" 
                                       Stroke="{TemplateBinding BorderBrush}" 
                                       StrokeThickness="{TemplateBinding BorderThickness}"/>
                            <Rectangle x:Name="PART_Indicator" 
                                       HorizontalAlignment="Left" 
                                       Fill="{TemplateBinding Foreground}">
                                <Rectangle.OpacityMask>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="Black" Offset="0"/>
                                        <GradientStop Color="Transparent" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.OpacityMask>
                            </Rectangle>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="PART_Indicator"
                                                         Storyboard.TargetProperty="Opacity"
                                                         From="0" To="1" Duration="0:0:0.5"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 窗口控制按钮样式 -->
        <Style TargetType="Button" x:Key="WindowControlButton">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF333333"/>
                </Trigger>
                <Trigger Property="Name" Value="btnClose">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation Storyboard.TargetProperty="Background.Color" To="Red" Duration="0:0:0.1"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="0" Background="#FF1E1E1E">
        <!-- 自定义标题栏 -->
        <Grid Height="30"  Background="#FF2D2D2D" VerticalAlignment="Top">
            <!-- 标题文本（可拖动窗口） -->
            <TextBlock Text="高级系统性能监控器" 
                       VerticalAlignment="Center" 
                       Margin="10 0 0 0"
                       Foreground="White"
                       MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"/>

            <!-- 窗口控制按钮 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Height="30">
                <Button Content="—" Style="{StaticResource WindowControlButton}" Click="BtnMinimize_Click"/>
                <Button x:Name="btnMaximize" Content="□" Style="{StaticResource WindowControlButton}" Click="BtnMaximize_Click"/>
                <Button x:Name="btnClose" Content="×" Style="{StaticResource WindowControlButton}" Click="BtnClose_Click"/>
            </StackPanel>
        </Grid>

        <!-- 主内容区域（避开标题栏） -->
        <Grid Margin="10 30 10 10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 10 0 10">
                <Button Content="导出数据" Width="80" Height="30" Click="ExportData_Click" 
                        Background="#FF2D2D2D" Foreground="White" BorderBrush="#FF555555"/>
                <Button Content="报警设置" Width="80" Height="30" Margin="10 0 0 0" Click="AlarmSettings_Click"
                        Background="#FF2D2D2D" Foreground="White" BorderBrush="#FF555555"/>
                <TextBlock Text="{Binding UpdateTime, StringFormat=最后更新: {0:HH:mm:ss}}" 
                           Margin="20 0 0 0" VerticalAlignment="Center" Style="{StaticResource ValueText}"/>
            </StackPanel>

            <!-- 基础监控面板 -->
            <Grid Grid.Row="1" Margin="0 10 0 10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- CPU监控 -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="CPU使用率" Style="{StaticResource TitleText}"/>
                    <ProgressBar Value="{Binding CpuUsage}" Minimum="0" Maximum="100" 
                                 Foreground="{Binding CpuColor}"/>
                    <TextBlock Text="{Binding CpuInfo}" Style="{StaticResource ValueText}" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- 内存监控 -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="内存使用率" Style="{StaticResource TitleText}"/>
                    <ProgressBar Value="{Binding MemoryUsage}" Minimum="0" Maximum="100" 
                                 Foreground="{Binding MemoryColor}"/>
                    <TextBlock Text="{Binding MemoryInfo}" Style="{StaticResource ValueText}" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- 网络监控 -->
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="网络速度" Style="{StaticResource TitleText}"/>
                    <ProgressBar Value="{Binding NetworkUsage}" Minimum="0" Maximum="100" 
                                 Foreground="#FF32CD32"/>
                    <TextBlock Text="{Binding NetworkInfo}" Style="{StaticResource ValueText}" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- CPU核心数 -->
                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                    <TextBlock Text="CPU核心信息" Style="{StaticResource TitleText}"/>
                    <Border Background="#FF2D2D2D" Width="150" Height="25" BorderBrush="#FF555555" BorderThickness="1" Margin="5">
                        <TextBlock Text="{Binding CpuCoreInfo}" Style="{StaticResource ValueText}" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="逻辑核心数" Style="{StaticResource ValueText}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- 图表和磁盘监控 -->
            <Grid Grid.Row="2" Margin="0 10 0 10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 历史数据图表（适配新版LiveCharts） -->
                <lvc:CartesianChart Grid.Column="0" Background="#FF2D2D2D" Margin="0 0 10 0">
                    <lvc:CartesianChart.Series>
                        <lvc:LineSeries Title="CPU使用率(%)" Values="{Binding CpuValues}" 
                                        Stroke="#FF00BFFF" PointGeometry="{x:Null}" LineSmoothness="1"/>
                        <lvc:LineSeries Title="内存使用率(%)" Values="{Binding MemoryValues}" 
                                        Stroke="#FFFF6347" PointGeometry="{x:Null}" LineSmoothness="1"/>
                        <lvc:LineSeries Title="网络使用率(%)" Values="{Binding NetworkValues}" 
                                        Stroke="#FF32CD32" PointGeometry="{x:Null}" LineSmoothness="1"/>
                    </lvc:CartesianChart.Series>
                    <lvc:CartesianChart.AxisX>
                        <lvc:Axis Title="时间(秒)" Foreground="White">
                            <lvc:Axis.Labels>
                                <Binding Path="TimeLabels"/>
                            </lvc:Axis.Labels>
                        </lvc:Axis>
                    </lvc:CartesianChart.AxisX>
                    <lvc:CartesianChart.AxisY>
                        <lvc:Axis Title="使用率(%)" Foreground="White" MinValue="0" MaxValue="100"/>
                    </lvc:CartesianChart.AxisY>
                    <!-- 新版LiveCharts图例配置 -->
                    <lvc:CartesianChart.LegendLocation>
                        <lvc1:LegendLocation >Top</lvc1:LegendLocation>
                    </lvc:CartesianChart.LegendLocation>
                    <!--<lvc:CartesianChart.Legend>
                        <lvc:DefaultLegend Position="Top" Foreground="White" Background="#FF2D2D2D"/>
                    </lvc:CartesianChart.Legend>-->
                </lvc:CartesianChart>

                <!-- 多磁盘监控 -->
                <ScrollViewer Grid.Column="1" Background="#FF2D2D2D" VerticalScrollBarVisibility="Auto" BorderBrush="#FF555555" BorderThickness="1">
                    <ItemsControl ItemsSource="{Binding DiskDrives}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5">
                                    <TextBlock Text="{Binding DriveName}" Style="{StaticResource TitleText}"/>
                                    <ProgressBar Value="{Binding Usage}" Minimum="0" Maximum="100" 
                                                 Foreground="#FF9370DB"/>
                                    <TextBlock Text="{Binding Info}" Style="{StaticResource ValueText}" 
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- 报警提示 -->
            <Border Grid.Row="3" Background="{Binding AlarmBackground}" Height="30" 
                    Visibility="{Binding AlarmVisibility}">
                <TextBlock Text="{Binding AlarmMessage}" Foreground="White" 
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </Grid>
</Window>